{
  "name": "react-inspector/event-loop",
  "description": "\ud83c\udf00 Measure the Event Loop",
  "license": "MIT",
  "authors": [
    {
      "name": "Cees-Jan Kiewiet",
      "email": "ceesjank@gmail.com",
      "homepage": "http://wyrihaximus.net/"
    }
  ],
  "require": {
    "php": "^7.4 || ^8.0",
    "evenement/evenement": "^3.0 || ^2.0",
    "react-inspector/global-state": "dev-switch-to-wyrihaximus-metrics-for-metrics",
    "react-inspector/metric": "^1.0",
    "react-inspector/metrics": "^1.0",
    "react/event-loop": "^1.3",
    "reactivex/rxphp": "^2.0",
    "wyrihaximus/constants": "^1.4",
    "wyrihaximus/iterator-or-array-to-array": "^1.1",
    "wyrihaximus/metrics": "^1.1",
    "wyrihaximus/metrics-lazy-registry": "^1.0"
  },
  "require-dev": {
    "ext-pcntl": "*",
    "thecodingmachine/safe": "^1.1",
    "wyrihaximus/async-test-utilities": "^4.0.7"
  },
  "autoload": {
    "psr-4": {
      "ReactInspector\\EventLoop\\": "src/"
    },
    "files": [
      "src/bootstrap_include.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "ReactInspector\\Tests\\EventLoop\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "infection/extension-installer": true,
      "ergebnis/composer-normalize": true,
      "icanhazstring/composer-unused": true
    },
    "platform": {
      "php": "7.4.7"
    },
    "sort-packages": true
  },
  "scripts": {
    "post-install-cmd": [
      "composer normalize"
    ],
    "post-update-cmd": [
      "composer normalize"
    ]
  }
}
